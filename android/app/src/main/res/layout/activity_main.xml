<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:background="#ff000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!-- Connect panel (shown when disconnected) -->
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/connectPanel"
        android:background="#66000000"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:fontFamily="@font/press_start_2p"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="GamepadBridge"/>
        <!-- Row: IP + QR -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <EditText
                android:textColor="#ffffff"
                android:textColorHint="#88ffffff"
                android:id="@+id/etHost"
                android:background="#33000000"
                android:padding="12dp"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="PC IP Address"
                android:inputType="phone"/>
            <ImageButton
                android:id="@+id/btnScanQR"
                android:src="@drawable/ic_qr"
                android:background="#44000000"
                android:contentDescription="Scan QR"
                android:scaleType="center"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <!-- Row: Port + QR -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <EditText
                android:textColor="#ffffff"
                android:textColorHint="#88ffffff"
                android:id="@+id/etPort"
                android:background="#33000000"
                android:padding="12dp"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="60001"
                android:hint="Port (default: 60001)"
                android:inputType="number"/>
            <ImageButton
                android:src="@drawable/ic_qr"
                android:background="#44000000"
                android:contentDescription="Scan QR"
                android:scaleType="center"
                android:clickable="false"
                android:focusable="false"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Connect"
            android:layout_marginTop="12dp"
            android:textAllCaps="false"/>
        <!-- Skin selector in connect panel -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp">
            <TextView
                android:textSize="10sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skins"
                android:layout_marginEnd="8dp"/>
            <View android:id="@+id/themeBlack" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_black" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themePink" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_pink" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themeBlue" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_blue" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themeYellow" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_yellow" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themeGreen" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_green" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44ffffff"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#88ffffff"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect your phone to your PC via WiFi\nthen enter the PC's IP and port above"/>
    </LinearLayout>

    <!-- PLAYER X centered full-screen (shown when connected) -->
    <TextView
        android:textSize="72sp"
        android:textStyle="bold"
        android:id="@+id/tvPlayerNumber"
        android:fontFamily="@font/press_start_2p"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:visibility="gone"
        android:includeFontPadding="false"
        android:text=""
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias="0.55"/>

    <!-- Gamepad status text (shown below PLAYER X when no gamepad detected) -->
    <TextView
        android:textSize="20sp"
        android:id="@+id/tvGamepadStatus"
        android:fontFamily="@font/press_start_2p"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:visibility="gone"
        android:includeFontPadding="false"
        android:text="(gamepad not detected, press a button?)"
        app:layout_constraintTop_toBottomOf="@id/tvPlayerNumber"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Options button (bottom-right, shown when connected) -->
    <TextView
        android:textSize="14sp"
        android:textColor="#ffffff"
        android:id="@+id/tvOptions"
        android:background="@drawable/options_bg"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:gravity="center"
        android:visibility="gone"
        android:text="options"
        android:clickable="true"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Options overlay panel -->
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/optionsPanel"
        android:background="#cc000000"
        android:padding="12dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- Close button -->
        <TextView
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:id="@+id/btnCloseOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✕"
            android:gravity="end"
            android:clickable="true"
            android:focusable="true"/>
        <!-- Skin selector -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <TextView
                android:textSize="10sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skins"
                android:layout_marginEnd="8dp"/>
            <View android:id="@+id/themeBlackO" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_black" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themePinkO" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_pink" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themeBlueO" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_blue" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themeYellowO" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_yellow" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
            <View android:id="@+id/themeGreenO" android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/circle_green" android:layout_marginHorizontal="3dp" android:clickable="true" android:focusable="true"/>
        </LinearLayout>
        <!-- Log toggle -->
        <Button
            android:id="@+id/btnToggleLog"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Log"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>
        <!-- Disconnect -->
        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Disconnect"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>
        <!-- Screen-off toggle -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">
            <TextView
                android:textSize="10sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen Off"
                android:layout_marginEnd="8dp"/>
            <Switch
                android:textColor="#ffffff"
                android:id="@+id/swScreenOff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""/>
        </LinearLayout>
    </LinearLayout>

    <!-- Log panel -->
    <TextView
        android:textSize="10sp"
        android:typeface="monospace"
        android:textColor="#88ffffff"
        android:id="@+id/tvLog"
        android:background="#88000000"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
