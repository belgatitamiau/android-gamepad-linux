<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:background="#ff000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!-- Connect panel (shown when disconnected) -->
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/connectPanel"
        android:background="#66000000"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="GamepadBridge"/>
        <EditText
            android:textColor="#ffffff"
            android:textColorHint="#88ffffff"
            android:id="@+id/etHost"
            android:background="#33000000"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="PC IP Address"
            android:inputType="phone"/>
        <EditText
            android:textColor="#ffffff"
            android:textColorHint="#88ffffff"
            android:id="@+id/etPort"
            android:background="#33000000"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="60001"
            android:hint="Port (default: 60001)"
            android:inputType="number"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="Connect"
                android:layout_weight="1"
                android:textAllCaps="false"/>
            <Button
                android:id="@+id/btnScanQR"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="QR"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <!-- Theme/skin selector in connect panel -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp">
            <TextView
                android:textSize="10sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skins"
                android:layout_marginEnd="8dp"/>
            <View
                android:id="@+id/themeBlack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_black"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themePink"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_pink"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeBlue"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_blue"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeYellow"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_yellow"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeGreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_green"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- PLAYER X centered full-screen (shown when connected) -->
    <TextView
        android:textSize="72sp"
        android:textStyle="bold"
        android:id="@+id/tvPlayerNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:visibility="gone"
        android:text=""
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Connected top bar (shown when connected) -->
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/connectedPanel"
        android:background="#66000000"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="12sp"
            android:textColor="#00ff00"
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:text="Connected"/>
        <Button
            android:id="@+id/btnToggleLog"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Log"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Disconnect"
            android:textAllCaps="false"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- Bottom settings panel (shown when connected) -->
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/settingsPanel"
        android:background="#66000000"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <!-- Theme/skin selector in settings panel -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="6dp">
            <TextView
                android:textSize="10sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skins"
                android:layout_marginEnd="8dp"/>
            <View
                android:id="@+id/themeBlackS"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_black"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themePinkS"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_pink"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeBlueS"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_blue"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeYellowS"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_yellow"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeGreenS"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/circle_green"
                android:layout_marginHorizontal="3dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
        <!-- Screen-off toggle -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">
            <TextView
                android:textSize="10sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen Off"
                android:layout_marginEnd="8dp"/>
            <Switch
                android:textColor="#ffffff"
                android:id="@+id/swScreenOff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""/>
        </LinearLayout>
        <!-- Furry art -->
        <TextView
            android:textSize="8sp"
            android:typeface="monospace"
            android:gravity="end"
            android:id="@+id/tvFurryArt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:lineSpacingExtra="0dp"
            android:alpha="0.5"/>
    </LinearLayout>

    <!-- Gamepad state list -->
    <TextView
        android:textSize="11sp"
        android:typeface="monospace"
        android:textColor="#aaffffff"
        android:id="@+id/tvGamepads"
        android:background="#44000000"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="No gamepads detected"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/tvLog"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/connectedPanel"/>

    <!-- Log panel (hidden by default) -->
    <TextView
        android:textSize="10sp"
        android:typeface="monospace"
        android:textColor="#88ffffff"
        android:id="@+id/tvLog"
        android:background="#88000000"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
