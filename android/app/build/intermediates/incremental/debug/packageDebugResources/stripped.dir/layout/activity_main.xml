<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:background="#ff000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!-- Connect panel (shown when disconnected) -->
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/connectPanel"
        android:background="#66000000"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="GamepadBridge"/>
        <EditText
            android:textColor="#ffffff"
            android:textColorHint="#88ffffff"
            android:id="@+id/etHost"
            android:background="#33000000"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="PC IP Address"
            android:inputType="phone"/>
        <EditText
            android:textColor="#ffffff"
            android:textColorHint="#88ffffff"
            android:id="@+id/etPort"
            android:background="#33000000"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="60001"
            android:hint="Port (default: 60001)"
            android:inputType="number"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="Connect"
                android:layout_weight="1"
                android:textAllCaps="false"/>
            <Button
                android:id="@+id/btnScanQR"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="QR"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
        <!-- Theme selector -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center">
            <TextView
                android:textSize="11sp"
                android:textColor="#88ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theme: "
                android:layout_marginEnd="8dp"/>
            <View
                android:id="@+id/themePink"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_pink"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeBlue"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_blue"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeYellow"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_yellow"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/themeGreen"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_green"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Connected panel (shown when connected) -->
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/connectedPanel"
        android:background="#66000000"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- Player number -->
        <TextView
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/tvPlayerNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text=""/>
        <!-- Status + buttons -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="#00ff00"
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Connected"
                android:layout_weight="1"/>
            <Button
                android:id="@+id/btnToggleLog"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Log"
                android:textAllCaps="false"
                android:layout_marginEnd="4dp"/>
            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Disconnect"
                android:textAllCaps="false"/>
        </LinearLayout>
        <TextView
            android:textSize="10sp"
            android:typeface="monospace"
            android:gravity="end"
            android:id="@+id/tvFurryArt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="0dp"
            android:alpha="0.7"/>
    </LinearLayout>

    <!-- Gamepad state list -->
    <TextView
        android:textSize="11sp"
        android:typeface="monospace"
        android:textColor="#aaffffff"
        android:id="@+id/tvGamepads"
        android:background="#44000000"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="No gamepads detected"
        app:layout_constraintBottom_toTopOf="@+id/tvLog"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/connectedPanel"/>

    <!-- Log (hidden by default, toggleable) -->
    <TextView
        android:textSize="10sp"
        android:typeface="monospace"
        android:textColor="#88ffffff"
        android:id="@+id/tvLog"
        android:background="#88000000"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
